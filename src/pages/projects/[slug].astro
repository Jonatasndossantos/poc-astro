---
import { getCollection, render } from "astro:content";
import { defaultLocale as locale, getTranslations, useTranslatedPath } from "@i18n";
import Layout from "@layouts/Layout.astro";

export async function getStaticPaths() {
    const projects = await getCollection("projects");

    return projects.map((project) => {
        const cleanId = project.id.replace(/\.mdx?$/, "");
        return {
            params: { slug: cleanId },
            props: { project, cleanId },
        };
    });
}

const { project, cleanId } = Astro.props;
const { Content } = await render(project);

const tPortfolio = (await getTranslations(locale, "portfolio")) as Record<string, any>;
const translatePath = useTranslatedPath(locale);
---

<Layout
    title={`${project.data.title} | Project`}
    description={project.data.title}
    lang={locale}
>
    <main class="w-full min-h-screen bg-base-100 pt-32 pb-20 px-6 lg:px-20 relative overflow-hidden">
        <div class="max-w-5xl mx-auto relative z-10">
             <a
                href={translatePath("/")}
                class="btn btn-ghost btn-sm mb-8 opacity-70 hover:opacity-100 uppercase tracking-widest text-xs"
            >
                &larr; {tPortfolio.taxonomy?.backToHome || 'Back'}
            </a>

            <header class="mb-16">
                <h1 class="text-5xl md:text-7xl font-bold font-syncopate mb-8 leading-tight">
                    {project.data.title}
                </h1>
                
                {project.data.heroImage && (
                    <div class="w-full aspect-video rounded-3xl overflow-hidden border border-base-content/10 shadow-2xl mb-12">
                        <img src={project.data.heroImage} alt={project.data.title} class="w-full h-full object-cover" />
                    </div>
                )}
            </header>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
                <div class="lg:col-span-2">
                    <article class="prose prose-lg prose-invert max-w-none prose-p:text-base-content/70">
                        <Content />
                    </article>
                </div>
                
                <aside class="space-y-8">
                    {project.data.tags && (
                        <div>
                            <h3 class="text-xs font-bold text-primary tracking-widest uppercase mb-4">Technologies</h3>
                            <div class="flex flex-wrap gap-2">
                                {project.data.tags.map((tag: any) => (
                                    <span class="badge badge-outline">{tag.id || tag}</span>
                                ))}
                            </div>
                        </div>
                    )}
                    
                    <div class="flex flex-col gap-3">
                        {project.data.demoUrl && (
                            <a href={project.data.demoUrl} target="_blank" class="btn btn-primary w-full">Live Demo</a>
                        )}
                        {project.data.repoUrl && (
                            <a href={project.data.repoUrl} target="_blank" class="btn btn-outline w-full">View Code</a>
                        )}
                    </div>
                </aside>
            </div>
        </div>
    </main>
</Layout>

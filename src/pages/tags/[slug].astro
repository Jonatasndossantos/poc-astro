---
import { getCollection, render } from "astro:content";
import { defaultLocale as locale, getTranslations, useTranslatedPath } from "@i18n";
import Layout from "@layouts/Layout.astro";
import GraphIsland from "@components/GraphIsland.astro";

export async function getStaticPaths() {
    const tags = await getCollection("tags");

    return tags.map((tag) => {
        const cleanId = tag.id.replace(/\.mdx?$/, "");
        return {
            params: { slug: cleanId },
            props: { tag, cleanId },
        };
    });
}

const { tag, cleanId } = Astro.props;

// Find all content that references this tag for en
const allProjects = await getCollection("projects");
const allBlogs = await getCollection("blog");

const relatedProjects = allProjects.filter((p) =>
    p.data.tags?.some(
        (ref: any) => (ref.id || ref).replace(/\.mdx?$/, "") === cleanId,
    ),
);

const relatedBlogs = allBlogs.filter((b) =>
    b.data.tags?.some(
        (ref: any) => (ref.id || ref).replace(/\.mdx?$/, "") === cleanId,
    ),
);

const { Content } = await render(tag);
const tPortfolio = (await getTranslations(locale, "portfolio")) as Record<string, any>;
const translatePath = useTranslatedPath(locale);
---

<Layout
    title={`${tag.data.title} | Taxonomy`}
    description={tag.data.description}
    lang={locale}
>
    <main
        class="w-full min-h-screen bg-base-100 pt-32 pb-20 px-6 lg:px-20 relative overflow-hidden"
    >
        <div class="max-w-4xl mx-auto relative z-10">
            <a
                href={translatePath("/ecosystem")}
                class="btn btn-ghost btn-sm mb-8 opacity-70 hover:opacity-100 uppercase tracking-widest text-xs"
            >
                &larr; {tPortfolio.taxonomy?.backToEcosystem || 'Back'}
            </a>

            <div class="flex items-center gap-6 mb-8">
                {
                    tag.data.icon ? (
                        <img
                            src={`https://cdn.simpleicons.org/${tag.data.icon}/ffffff`}
                            alt={tag.data.title}
                            class="w-16 h-16 object-contain"
                        />
                    ) : (
                        <div class="w-16 h-16 rounded bg-base-200 flex items-center justify-center text-3xl font-bold">
                            {tag.data.title.charAt(0)}
                        </div>
                    )
                }
                <div>
                    <span
                        class="badge badge-primary badge-outline uppercase tracking-wider text-xs mb-2"
                    >
                        {tag.data.category}
                    </span>
                    <h1 class="text-5xl font-bold font-syncopate">
                        {tag.data.title}
                    </h1>
                </div>
            </div>

            <article
                class="prose prose-lg prose-invert mb-16 max-w-none prose-p:text-base-content/70"
            >
                <Content />
            </article>

            <div class="mb-16">
                <h2
                    class="text-2xl font-bold mb-6 border-b border-base-content/10 pb-4"
                >
                    {tPortfolio.graph?.knowledgeTitle || 'Knowledge Graph'}
                </h2>
                <GraphIsland focusId={`tags/${cleanId}`} />
            </div>

            {
                relatedProjects.length > 0 && (
                    <div class="mb-12">
                        <h2 class="text-2xl font-bold mb-6 border-b border-base-content/10 pb-4">
                            Relatd Projects: {tag.data.title}
                        </h2>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            {relatedProjects.map((p) => (
                                <a
                                    href={translatePath(`/projects/${p.id.replace(/\.mdx?$/, "")}`)}
                                    class="card bg-base-200/50 hover:bg-base-200 transition-colors border border-base-content/5"
                                >
                                    <div class="card-body p-6">
                                        <h3 class="card-title text-lg">
                                            {p.data.title}
                                        </h3>
                                        <p class="text-sm opacity-70 line-clamp-2">
                                            View Case Study &rarr;
                                        </p>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </div>
                )
            }
        </div>
    </main>
</Layout>

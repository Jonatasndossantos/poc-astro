---
import { getCollection, render } from "astro:content";
import { defaultLocale as locale, getTranslations, useTranslatedPath } from "@i18n";
import Layout from "@layouts/Layout.astro";
import GraphIsland from "@components/GraphIsland.astro";

export async function getStaticPaths() {
    const topics = await getCollection("topics");

    return topics.map((topic) => {
        const cleanId = topic.id.replace(/\.mdx?$/, "");
        return {
            params: { slug: cleanId },
            props: { topic, cleanId },
        };
    });
}

const { topic, cleanId } = Astro.props;

const { Content } = await render(topic);
const tPortfolio = (await getTranslations(locale, "portfolio")) as Record<string, any>;
const translatePath = useTranslatedPath(locale);
---

<Layout
    title={`${topic.data.title} | Topic`}
    description={topic.data.description}
    lang={locale}
>
    <main class="w-full min-h-screen bg-base-100 pt-32 pb-20 px-6 lg:px-20 relative overflow-hidden">
        <div class="max-w-4xl mx-auto relative z-10">
            <a
                href={translatePath("/ecosystem")}
                class="btn btn-ghost btn-sm mb-8 opacity-70 hover:opacity-100 uppercase tracking-widest text-xs"
            >
                &larr; {tPortfolio.taxonomy?.backToEcosystem || 'Back'}
            </a>

            <h1 class="text-5xl md:text-6xl font-bold font-syncopate mb-12">
                {topic.data.title}
            </h1>

            <article class="prose prose-lg prose-invert mb-16 max-w-none prose-p:text-base-content/70">
                <Content />
            </article>

            <div class="mt-20">
                <h2 class="text-2xl font-bold mb-8">{tPortfolio.graph?.knowledgeTitle || 'Knowledge Graph'}</h2>
                <GraphIsland focusId={`topics/${cleanId}`} />
            </div>
        </div>
    </main>
</Layout>

---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import { getTranslations, defaultLocale as locale } from "@i18n";

const tPortfolio = (await getTranslations(locale, "portfolio")) as Record<string, any>;

const allTags = await getCollection("tags");

import TechCard from "@components/ui/TechCard.astro";

// Pre-process sorting
allTags.sort((a, b) => a.data.title.localeCompare(b.data.title));

// Extract unique categories for filter tabs
const categories = [...new Set(allTags.map((tag) => tag.data.category))].sort();
---

<Layout
    title="Ecosystem | Verdant Visual"
    description="A complete taxonomy of my technological skills, frameworks, and tools."
    lang={locale}
>
    <main
        class="w-full min-h-screen bg-base-100 pt-32 pb-20 px-6 lg:px-20 relative overflow-hidden"
    >
        <div class="max-w-7xl mx-auto relative z-10">
            <h1 class="text-5xl md:text-7xl font-bold font-syncopate mb-6">
                Tech <span class="text-primary opacity-80">{tPortfolio.ecosystem.title.replace("Tech ", "")}</span>
            </h1>
            <p class="text-xl opacity-70 mb-12 max-w-2xl text-balance">
                {tPortfolio.ecosystem.desc}
            </p>

            <!-- Search & Filtering Engine -->
            <div
                class="flex flex-col md:flex-row gap-4 mb-10 w-full justify-between items-center bg-base-200/50 p-4 rounded-2xl backdrop-blur-sm border border-base-content/5"
                id="filter-controls"
            >
                <div class="relative w-full md:w-96">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-5 w-5 absolute left-4 top-1/2 -translate-y-1/2 opacity-50"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                        ></path></svg
                    >
                    <input
                        type="text"
                        id="search-input"
                        placeholder={tPortfolio.ecosystem.search}
                        class="input input-bordered w-full pl-12 bg-base-100/50 focus:bg-base-100 transition-colors"
                        aria-label={tPortfolio.ecosystem.search}
                    />
                </div>

                <div class="flex gap-2 flex-wrap justify-end">
                    <button
                        class="btn btn-sm btn-active filter-btn"
                        data-category="all"
                        aria-label={tPortfolio.ecosystem.all || "All"}>{tPortfolio.ecosystem.all || "All"}</button
                    >
                    {
                        categories.map((cat) => (
                            <button
                                class="btn btn-sm filter-btn uppercase text-xs"
                                data-category={cat}
                                aria-label={`${tPortfolio.ecosystem.filterBy || "Filter by"} ${cat}`}
                            >
                                {cat}
                            </button>
                        ))
                    }
                </div>
            </div>

            <!-- Ecosystem Grid -->
            <div
                class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4"
                id="ecosystem-grid"
            >
                {
                    allTags.map((tag) => (
                        <TechCard 
                            id={tag.id}
                            title={tag.data.title}
                            description={tag.data.description}
                            icon={tag.data.icon}
                            category={tag.data.category}
                            lang={locale}
                        />
                    ))
                }
            </div>

            <div id="no-results" class="hidden text-center py-20 w-full">
                <p class="text-2xl font-bold opacity-30">
                    {tPortfolio.ecosystem.noResults}
                </p>
                <p class="text-sm opacity-50 mt-2">
                    {tPortfolio.ecosystem.tryAdjusting}
                </p>
            </div>
        </div>
    </main>
</Layout>

<script>
    // Vanilla JS Client-Side Filtering (0-React)
    function setupFilters() {
        const searchInput = document.getElementById(
            "search-input",
        ) as HTMLInputElement;
        const filterBtns = document.querySelectorAll(".filter-btn");
        const cards = document.querySelectorAll(".ecosystem-card");
        const noResults = document.getElementById("no-results");

        if (!searchInput || !filterBtns.length || !cards.length) return;

        let currentSearch = "";
        let currentCategory = "all";

        const applyFilters = () => {
            let visibleCount = 0;

            cards.forEach((c) => {
                const card = c as HTMLElement;
                const matchesSearch =
                    card.dataset.title?.includes(currentSearch) || false;
                const matchesCategory =
                    currentCategory === "all" ||
                    card.dataset.category === currentCategory;

                if (matchesSearch && matchesCategory) {
                    card.style.display = "flex";
                    // Trigger reflow for animation
                    void card.offsetWidth;
                    card.style.opacity = "1";
                    card.style.transform = "translateY(0)";
                    visibleCount++;
                } else {
                    card.style.opacity = "0";
                    card.style.transform = "translateY(10px)";
                    setTimeout(() => {
                        if (card.style.opacity === "0")
                            card.style.display = "none";
                    }, 300);
                }
            });

            if (noResults) {
                noResults.classList.toggle("hidden", visibleCount > 0);
            }
        };

        // Search Listener
        searchInput.addEventListener("input", (e) => {
            currentSearch = (e.target as HTMLInputElement).value.toLowerCase();
            applyFilters();
        });

        // Category Listeners
        filterBtns.forEach((btn) => {
            btn.addEventListener("click", (e) => {
                // Update active button styling
                filterBtns.forEach((b) =>
                    b.classList.remove("btn-active", "btn-primary"),
                );
                const target = e.currentTarget as HTMLElement;
                target.classList.add("btn-active");
                if (target.dataset.category !== "all")
                    target.classList.add("btn-primary");

                currentCategory = target.dataset.category || "all";
                applyFilters();
            });
        });
    }

    // Run on init and Astro view transitions
    document.addEventListener("astro:page-load", setupFilters);
    setupFilters();
</script>

---
import { getCollection } from "astro:content";
import { defaultLocale as locale, useTranslator } from "@i18n";
import Layout from "@layouts/Layout.astro";

const __ = await useTranslator(locale);

// Fetch all blog posts
const allPosts = await getCollection("blog");

// Filter for default locale (en) and not drafts
const publishedPosts = allPosts.filter((post) => 
    !post.data.draft && post.id.startsWith(`${locale}/`)
);

// Sort by date descending
const posts = publishedPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
    title={__("Blog")}
    description={__("Developer Blog")}
    lang={locale}
>
    <main class="w-full min-h-screen bg-base-100 pt-32 pb-20 px-6 lg:px-20 relative">
        <div class="max-w-4xl mx-auto z-10 relative">
            <h1 class="text-4xl md:text-5xl font-bold font-syncopate mb-12">
                {__("Blog")}
            </h1>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {posts.map((post) => {
                    const cleanSlug = post.id.split('/').slice(1).join('/').replace(/\.mdx?$/, "");
                    return (
                        <a 
                            href={`/blog/${cleanSlug}`}
                            class="card bg-base-200/50 hover:bg-base-200 transition-colors border border-base-content/5 group"
                        >
                            <div class="card-body">
                                <h2 class="card-title text-2xl group-hover:text-primary transition-colors">
                                    {post.data.title}
                                </h2>
                                <p class="text-sm opacity-60 mb-4">
                                    {new Date(post.data.date).toLocaleDateString(locale, {
                                        year: 'numeric',
                                        month: 'long',
                                        day: 'numeric'
                                    })}
                                </p>
                                <div class="card-actions justify-end mt-auto">
                                    <span class="bg-primary text-primary-content text-xs font-bold px-3 py-1 rounded-full group-hover:-translate-y-1 transition-transform">
                                        {__("Read more")} &rarr;
                                    </span>
                                </div>
                            </div>
                        </a>
                    )
                })}
            </div>
            
            {posts.length === 0 && (
                 <div class="text-center py-20 opacity-50 border border-dashed border-base-content/20 rounded-xl">
                    No articles found in this language yet.
                </div>
            )}
        </div>
    </main>
</Layout>

---
import { getCollection, render } from "astro:content";
import { defaultLocale as locale, useTranslator, useTranslatedPath } from "@i18n";
import Layout from "@layouts/Layout.astro";

export async function getStaticPaths() {
    const allPosts = await getCollection("blog");
    
    // Only generate paths for English posts at the root
    const enPosts = allPosts.filter(p => p.id.startsWith(`${locale}/`));

    return enPosts.map(post => {
        const cleanSlug = post.id.split('/').slice(1).join('/').replace(/\.mdx?$/, "");
        return {
            params: { slug: cleanSlug },
            props: { post }
        };
    });
}

const { post } = Astro.props;
const { Content } = await render(post);

const __ = await useTranslator(locale);
const translatePath = useTranslatedPath(locale);
---

<Layout
    title={`${post.data.title} | ${__("Blog")}`}
    description={post.data.title}
    lang={locale}
>
    <main class="w-full min-h-screen bg-base-100 pt-32 pb-20 px-6 lg:px-20 relative">
        <div class="max-w-3xl mx-auto z-10 relative">
            <a
                href={translatePath("/blog")}
                class="btn btn-ghost btn-sm mb-8 opacity-70 hover:opacity-100 uppercase tracking-widest text-xs"
            >
                &larr; {__("Back to Blog")}
            </a>

            <header class="mb-12 border-b border-base-content/10 pb-8">
                <div class="flex items-center gap-4 mb-4">
                    <span class="badge badge-primary badge-outline uppercase tracking-wider text-xs">
                        {__("Article")}
                    </span>
                    <time class="text-sm opacity-60 font-mono">
                         {new Date(post.data.date).toLocaleDateString(locale, {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric'
                        })}
                    </time>
                </div>
                <h1 class="text-4xl md:text-5xl font-bold font-syncopate leading-tight">
                    {post.data.title}
                </h1>
            </header>

            <article class="prose prose-lg prose-invert max-w-none prose-p:text-base-content/80">
                <Content />
            </article>
        </div>
    </main>
</Layout>

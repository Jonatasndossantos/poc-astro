---
import HomeIndex from "@components/pages/home/Index.astro";
import { defaultLocale as locale } from "@i18n";

// This is the root index file for the default locale (no prefix)
// It uses the standardized HomeIndex component with a localized redirection script.
---

<HomeIndex lang={locale}>
    <script is:inline>
        // Automatic language detection and redirection for first-time visitors
        const supportedLocales = ["en", "pt", "fr", "es", "zh", "ja"];
        const defaultLocale = "en";

        const preferredLocale = localStorage.getItem("preferred-locale");

        if (
            preferredLocale &&
            preferredLocale !== defaultLocale &&
            supportedLocales.includes(preferredLocale)
        ) {
            // Respect existing preference
            window.location.pathname = `/${preferredLocale}/`;
        } else if (!preferredLocale) {
            // First visit: detect browser language
            const browserLang =
                (navigator.languages && navigator.languages[0]) ||
                navigator.language ||
                "";
            const shortLang = browserLang.split("-")[0].toLowerCase();

            if (
                shortLang !== defaultLocale &&
                supportedLocales.includes(shortLang)
            ) {
                localStorage.setItem("preferred-locale", shortLang);
                window.location.pathname = `/${shortLang}/`;
            } else {
                // Set default preference so we don't keep detecting
                localStorage.setItem("preferred-locale", defaultLocale);
            }
        }
    </script>
</HomeIndex>

---
import { getCollection, render } from "astro:content";
import { defaultLocale as locale, getTranslations, useTranslatedPath } from "@i18n";
import Layout from "@layouts/Layout.astro";

// This file is only for the default locale (no prefix)
export async function getStaticPaths() {
    const services = await getCollection("services");
    return services.map((service) => {
        const cleanId = service.id.replace(/\.mdx?$/, "");
        return {
            params: { slug: cleanId },
            props: { service, cleanId },
        };
    });
}

const { service, cleanId } = Astro.props;
const { Content } = await render(service);

const tPortfolio = (await getTranslations(locale, "portfolio")) as Record<string, any>;
const translatePath = useTranslatedPath(locale);
---

<Layout
    title={`${service.data.title} | ${tPortfolio.services?.title || 'Service'}`}
    description={service.data.title}
    lang={locale}
>
    <main class="w-full min-h-screen bg-base-100 pt-32 pb-20 px-6 lg:px-20 relative overflow-hidden">
        <div class="max-w-4xl mx-auto relative z-10">
            <a
                href={translatePath("/ecosystem")}
                class="btn btn-ghost btn-sm mb-8 opacity-70 hover:opacity-100 uppercase tracking-widest text-xs"
            >
                &larr; {tPortfolio.taxonomy?.backToEcosystem || 'Back'}
            </a>

            <div class="flex items-center gap-6 mb-12">
                {service.data.icon && (
                    <div class="w-20 h-20 rounded-2xl bg-primary/10 flex items-center justify-center p-4">
                         <img
                            src={`https://cdn.simpleicons.org/${service.data.icon}/ffffff`}
                            alt={service.data.title}
                            class="w-full h-full object-contain"
                        />
                    </div>
                )}
                <div>
                    <h1 class="text-5xl md:text-6xl font-bold font-syncopate">
                        {service.data.title}
                    </h1>
                </div>
            </div>

            <article class="prose prose-lg prose-invert max-w-none prose-p:text-base-content/70">
                <Content />
            </article>
        </div>
    </main>
</Layout>

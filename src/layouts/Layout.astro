---
import "../assets/global.css";
import NavBar from "../components/layout/NavBar.astro";
import MobileDrawer from "../components/layout/MobileDrawer.astro";

interface Props {
	title?: string;
	description?: string;
	lang?: string;
	canonicalUrl?: string;
	image?: string;
}

const {
	title = "Jônatas N. dos Santos - Software Engineer",
	description = "Portfólio Oficial — Especialista Full-Stack, IA e Arquitetura de Software",
	lang = "pt",
	canonicalUrl = Astro.url.href,
	image = "/og-image.png",
} = Astro.props;

const ogTitle = title === "Jônatas N. dos Santos" ? title : `${title} | Jônatas N. dos Santos`;
const fullImageUrl = new URL(image, Astro.url).href;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="theme-color" content="#000000" />

		<!-- Primary SEO -->
		<title>{ogTitle}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<meta name="author" content="Jônatas Nascimento dos Santos" />
		<link rel="canonical" href={canonicalUrl} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={ogTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:locale" content={lang} />
		<meta property="og:image" content={fullImageUrl} />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalUrl} />
		<meta name="twitter:title" content={ogTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={fullImageUrl} />

		<!-- Icons -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<link
			rel="icon"
			type="image/png"
			href="/favicon-96x96.png"
			sizes="96x96"
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link rel="manifest" href="/site.webmanifest" />

		<!-- Theme Initialization -->
		<script is:inline>
			(function() {
				const savedTheme = localStorage.getItem('theme');
				if (savedTheme) {
					document.documentElement.setAttribute('data-theme', savedTheme);
				} else {
					// Default to a sensible theme if none saved
					document.documentElement.setAttribute('data-theme', 'cupcake');
				}
			})();
		</script>
	</head>
	<body>
		<div class="drawer drawer-end">
			<!-- Drawer toggle -> linked to the hamburger button in NavBar -->
			<input id="mobile-menu" type="checkbox" class="drawer-toggle" />
			
			<div class="drawer-content flex flex-col">
				<NavBar lang={lang} />
				<slot />
			</div>

			<!-- Component containing the .drawer-side structure -->
			<MobileDrawer lang={lang} />
		</div>

		<!-- global styles for HTML scroll-behavior removed to avoid conflicts with Lenis -->
	</body>
</html>

---
import Layout from "@layouts/Layout.astro";
import { getEntry, render } from "astro:content";
import { getTranslations, useTranslatedPath } from "@i18n";

const { project, lang: locale } = Astro.props;
const tPortfolio = (await getTranslations(locale, "portfolio")) as Record<string, any>;
const translatePath = useTranslatedPath(locale);
const { Content } = await render(project);

// Manually resolve relationships using Astro Content Collections getEntry
const resolveReference = async (
    ref: any,
    defaultCollection: "services" | "blog",
) => {
    if (!ref) return null;
    try {
        if (typeof ref === "string") {
            return await getEntry(defaultCollection, ref);
        } else if (typeof ref === "object" && ref.collection && ref.id) {
            return await getEntry(ref.collection, ref.id);
        }
        return null;
    } catch (e) {
        console.warn(`Failed to resolve reference:`, ref, e);
        return null;
    }
};

const relatedServicesRaw =
    project.data.relatedServices && project.data.relatedServices.length > 0
        ? await Promise.all(
              project.data.relatedServices.map((ref: any) =>
                  resolveReference(ref, "services"),
              ),
          )
        : [];
const relatedServices = relatedServicesRaw.filter(Boolean);

const relatedPostsRaw =
    project.data.relatedPosts && project.data.relatedPosts.length > 0
        ? await Promise.all(
              project.data.relatedPosts.map((ref: any) =>
                  resolveReference(ref, "blog"),
              ),
          )
        : [];
const relatedPosts = relatedPostsRaw.filter(Boolean);
---

<Layout title={`${project.data.title} | ${tPortfolio.projects.caseStudy}`} lang={locale}>
    <main
        class="w-full min-h-screen bg-base-100 text-base-content pt-32 pb-20 px-6 lg:px-20 relative z-10"
    >
        <div class="max-w-4xl mx-auto">
            <header class="mb-12 text-center md:text-left">
                <div class="flex flex-wrap items-center gap-3 justify-center md:justify-start mb-4">
                    <span class="badge badge-primary badge-sm uppercase font-bold tracking-wider">{tPortfolio.projects.caseStudy || "Case Study"}</span>
                    {project.data.date && <span class="badge badge-neutral badge-sm opacity-80">{new Date(project.data.date).getFullYear()}</span>}
                </div>
                
                <h1 class="text-4xl md:text-6xl font-black text-transparent bg-clip-text bg-gradient-to-br from-base-content to-base-content/50 mb-6 leading-tight">
                    {project.data.title}
                </h1>
                
                <div class="flex flex-wrap items-center gap-6 text-sm font-medium opacity-80 justify-center md:justify-start">
                    {project.data.role && (
                        <div class="flex items-center gap-2">
                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
                            {project.data.role}
                        </div>
                    )}
                    {project.data.company && (
                        <div class="flex items-center gap-2">
                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>
                            {project.data.company}
                        </div>
                    )}
                </div>
                
                {project.data.tags && project.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mt-6 justify-center md:justify-start">
                        {project.data.tags.map((tag: string) => (
                            <span class="badge badge-outline border-base-content/20 text-xs text-base-content/70">{tag}</span>
                        ))}
                    </div>
                )}
            </header>

            {
                project.data.heroImage && (
                    <div class="w-full h-72 md:h-[500px] rounded-3xl overflow-hidden mb-16 shadow-2xl relative">
                        <img
                            src={project.data.heroImage}
                            alt={project.data.title}
                            class="absolute inset-0 w-full h-full object-cover"
                        />
                    </div>
                )
            }

            <article class="prose prose-lg prose-invert max-w-none">
                <Content />
            </article>

            <hr class="my-16 border-base-content/10" />

            <!-- The Second Brain Funnel -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 not-prose">
                {
                    relatedPosts.length > 0 && (
                        <div class="bg-base-200/50 p-6 rounded-2xl">
                            <h3 class="text-xl font-bold mb-4">
                                {tPortfolio.taxonomy.contextDeepDives}
                            </h3>
                            <p class="text-sm opacity-80 mb-4">
                                {tPortfolio.taxonomy.readMoreTech}
                            </p>
                            <ul class="space-y-3">
                                {relatedPosts.map((post) => (
                                    <li>
                                        <a
                                            href={`/${locale}/blog/${post.slug}`}
                                            class="text-primary hover:text-primary/80 transition-colors flex items-center gap-2 font-medium"
                                        >
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                width="16"
                                                height="16"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                class="lucide lucide-file-text"
                                            >
                                                <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
                                                <path d="M14 2v4a2 2 0 0 0 2 2h4" />
                                                <path d="M10 9H8" />
                                                <path d="M16 13H8" />
                                                <path d="M16 17H8" />
                                            </svg>
                                            {post.data.title}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    )
                }

                {
                    relatedServices.length > 0 && (
                        <div class="bg-primary/5 p-6 rounded-2xl border border-primary/20">
                            <h3 class="text-xl font-bold mb-4 text-primary">
                                {tPortfolio.taxonomy.needSimilarResults}
                            </h3>
                            <p class="mb-5 opacity-80 text-sm">
                                {tPortfolio.taxonomy.specializedServices}
                            </p>
                            <div class="flex flex-col gap-3">
                                {relatedServices.map((service) => (
                                    <a
                                        href={`/${locale}/services/${service.slug}`}
                                        class="btn btn-primary btn-outline flex justify-between items-center group"
                                    >
                                        <span>{service.data.title}</span>
                                        <span class="group-hover:translate-x-1 transition-transform">
                                            →
                                        </span>
                                    </a>
                                ))}
                            </div>
                        </div>
                    )
                }
            </div>

            <div class="mt-16 text-center not-prose">
                <a
                    href={translatePath("/")}
                    class="btn btn-ghost rounded-full px-8"
                    >{tPortfolio.taxonomy.backToPortfolio}</a
                >
            </div>
        </div>
    </main>
</Layout>

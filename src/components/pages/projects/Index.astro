---
import { getCollection } from "astro:content";
import { getTranslations } from "@i18n";
import Layout from "@layouts/Layout.astro";

const { lang: locale } = Astro.props;
const tPortfolio = (await getTranslations(locale, "portfolio")) as Record<string, any>;
const allProjects = await getCollection("projects");

---

<Layout
    title={`Projects | ${tPortfolio.projects.caseStudy}`}
    description="Showcase of professional projects and experiments."
    lang={locale}
>
    <main class="w-full min-h-screen bg-base-100 pt-32 pb-20 px-6 lg:px-20 relative">
        <div class="max-w-7xl mx-auto z-10 relative">
            <h1 class="text-4xl md:text-5xl font-bold font-syncopate mb-12">
                Projects
            </h1>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {allProjects.map((p) => {
                    const cleanId = p.id.replace(/\.mdx?$/, "");
                    return (
                        <a 
                            href={`/${locale}/projects/${cleanId}`}
                            class="card bg-base-200/50 hover:bg-base-200 transition-colors border border-base-content/5 group overflow-hidden"
                        >
                            {p.data.heroImage && (
                                <figure class="h-48 overflow-hidden">
                                    <img src={p.data.heroImage} alt={p.data.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                </figure>
                            )}
                            <div class="card-body p-8">
                                <h2 class="card-title text-2xl group-hover:text-primary transition-colors mb-2">
                                    {p.data.title}
                                </h2>
                                <p class="opacity-70 mb-6">Case study of professional work</p>
                                <div class="card-actions justify-end">
                                    <span class="btn btn-primary btn-outline">View Case &rarr;</span>
                                </div>
                            </div>
                        </a>
                    );
                })}
            </div>
        </div>
    </main>
</Layout>

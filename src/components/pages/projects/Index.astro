---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import { getTranslations, useTranslatedPath } from "@i18n";
import SectionHeader from "@components/ui/SectionHeader.astro";
import SearchFilters from "@components/ui/SearchFilters.astro";
import ProjectCard from "@components/ui/ProjectCard.astro";
import GraphIsland from "@components/GraphIsland.astro";

const { lang: locale } = Astro.props;
const tPortfolio = (await getTranslations(locale, "portfolio")) as Record<
    string,
    any
>;
const translatePath = useTranslatedPath(locale);

const allProjects = await getCollection("projects");

// Pre-process projects for consistent card mapping
const projectsData = allProjects.map((p) => {
    const cleanId = p.id.replace(/\.mdx?$/, "");
    return {
        id: cleanId,
        title: p.data.title,
        imageUrl: p.data.heroImage || "",
        demoUrl: p.data.demoUrl,
        repoUrl: p.data.repoUrl,
        technologies: p.data.tags
            ? p.data.tags.map((t: any) => ({
                  id: (t.id || t).replace(/\.mdx?$/, ""),
                  name: (t.id || t).split('/').pop()?.replace(/-/g, " ") || "Tech",
              }))
            : [],
        displayDescriptionTextKey: `projects.items.${cleanId}.description.fullstack`,
    };
});
---

<Layout
    title={tPortfolio.projects.title}
    description={tPortfolio.projects.desc || tPortfolio.projects.title}
    lang={locale}
>
    <main class="w-full min-h-screen bg-base-100 pt-32 pb-20 px-6 lg:px-20 relative">
        <div class="max-w-7xl mx-auto">
            <SectionHeader 
                label={tPortfolio.projects.label}
                title={tPortfolio.projects.title}
                highlightedTitle={tPortfolio.projects.highlightedTitle}
                description={tPortfolio.projects.desc}
                viewAllLink={translatePath("/ecosystem")}
                viewAllLabel={tPortfolio.ui.exploreKnowledge}
            />

            <SearchFilters 
                searchPlaceholder={tPortfolio.knowledge.search}
                allLabel={tPortfolio.knowledge.all}
                filterByLabel={tPortfolio.knowledge.filterBy}
                gridId="projects-grid"
                cardClass="project-card-filter"
            />

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="projects-grid">
                {
                    projectsData.map((project) => (
                        <div class="project-card-filter h-full" data-title={project.title}>
                            <ProjectCard 
                                project={project}
                                lang={locale}
                                caseStudyLabel={tPortfolio.projects.caseStudy}
                                viewProjectLabel={tPortfolio.projects.viewProject}
                                codeLabel={tPortfolio.projects.code}
                            />
                        </div>
                    ))
                }
            </div>

            <div id="no-results" class="hidden text-center py-20 w-full bg-base-200/20 rounded-3xl border border-dashed border-base-content/10 mt-8">
                <p class="text-2xl font-bold opacity-30">
                    {tPortfolio.knowledge.noResults}
                </p>
                <p class="text-sm opacity-50 mt-2">
                    {tPortfolio.knowledge.tryAdjusting}
                </p>
            </div>

            <!-- Knowledge Graph Section -->
            <div class="mt-32">
                 <SectionHeader 
                    label={tPortfolio.graph.title}
                    title={tPortfolio.ui.Interactive}
                    highlightedTitle={tPortfolio.ui["Knowledge Graph"]}
                 />
                 <GraphIsland lang={locale} />
            </div>
        </div>
    </main>
</Layout>

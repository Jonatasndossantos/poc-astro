---
import { getCollection } from "astro:content";
import { getTranslations } from "@i18n";
import Layout from "@layouts/Layout.astro";

const { lang: locale } = Astro.props;
const tPortfolio = (await getTranslations(locale, "portfolio")) as Record<string, any>;
const allServices = await getCollection("services");

---

<Layout
    title={`Services | ${tPortfolio.ecosystem.title}`}
    description="Professional services and offerings."
    lang={locale}
>
    <main class="w-full min-h-screen bg-base-100 pt-32 pb-20 px-6 lg:px-20 relative">
        <div class="max-w-4xl mx-auto z-10 relative">
            <h1 class="text-4xl md:text-5xl font-bold font-syncopate mb-12">
                Services
            </h1>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {allServices.map((service) => (
                    <a 
                        href={`/${locale}/services/${service.id.replace(/\.mdx?$/, "")}`}
                        class="card bg-base-200/50 hover:bg-base-200 transition-colors border border-base-content/5 group"
                    >
                        <div class="card-body p-8">
                            <h2 class="card-title text-2xl group-hover:text-primary transition-colors mb-4">
                                {service.data.title}
                            </h2>
                            <p class="opacity-70 mb-6">Professional tailored service</p>
                            <div class="card-actions justify-end">
                                <span class="btn btn-primary btn-sm">Learn More</span>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </main>
</Layout>

---
import { getCollection, render } from "astro:content";
import { getTranslations, useTranslatedPath } from "@i18n";
import Layout from "@layouts/Layout.astro";
import GraphIsland from "@components/GraphIsland.astro";
import Services from "@components/sections/Services.astro";

const { lang: locale, service, cleanId } = Astro.props;

// Find all content that references this service
const allProjects = await getCollection("projects");
const allBlogs = await getCollection("blog");

const relatedProjects = allProjects.filter((p) =>
    p.data.relatedServices?.some((ref: any) => {
        const refId = typeof ref === "string" ? ref : ref.id;
        return refId.replace(/\.mdx?$/, "") === cleanId;
    }),
);

// ctaService is a single reference, not an array
const relatedBlogs = allBlogs.filter((b) => {
    if (!b.data.ctaService) return false;
    const ctaId =
        typeof b.data.ctaService === "string"
            ? b.data.ctaService
            : (b.data.ctaService as any).id;
    return ctaId.replace(/\.mdx?$/, "") === cleanId;
});

const { Content } = await render(service);
const tPortfolio = (await getTranslations(locale, "portfolio")) as Record<
    string,
    any
>;
const translatePath = useTranslatedPath(locale);
---

<Layout
    title={`${service.data.title} | Services`}
    description={`Service details for ${service.data.title}`}
    lang={locale}
>
    <main
        class="w-full min-h-screen bg-base-100 pt-32 pb-20 px-6 lg:px-20 relative overflow-hidden"
    >
        <div class="max-w-7xl mx-auto relative z-10">
            <a
                href={translatePath("/")}
                class="btn btn-ghost btn-sm mb-8 opacity-70 hover:opacity-100 uppercase tracking-widest text-xs"
            >
                {tPortfolio.taxonomy.backToPortfolio}
            </a>

            <div
                class="flex flex-col md:flex-row md:items-center gap-6 mb-8 justify-between"
            >
                <div class="flex items-center gap-6">
                    {
                        service.data.icon ? (
                            <div class="w-16 h-16 rounded bg-base-200 flex items-center justify-center text-3xl">
                                {service.data.icon}
                            </div>
                        ) : (
                            <div class="w-16 h-16 rounded bg-base-200 flex items-center justify-center text-base-content/60 shadow-inner">
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect><circle cx="9" cy="9" r="2"></circle><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path></svg>
                            </div>
                        )
                    }
                    <div>
                        <span
                            class="badge badge-primary badge-outline uppercase tracking-wider text-xs mb-2"
                        >
                            {tPortfolio.services.title.replace(/s$/i, "")}
                        </span>
                        <h1
                            class="text-4xl md:text-5xl font-bold font-syncopate"
                        >
                            {service.data.title}
                        </h1>
                    </div>
                </div>
                {
                    service.data.priceStartingAt && (
                        <div class="text-left md:text-right mt-4 md:mt-0 p-4 bg-base-200 rounded-xl border border-base-content/10">
                            <div class="text-sm opacity-70 uppercase tracking-wider mb-1">
                                {tPortfolio.taxonomy.startingAt}
                            </div>
                            <div class="text-3xl font-bold text-primary">
                                ${service.data.priceStartingAt}
                            </div>
                        </div>
                    )
                }
            </div>

            <article
                class="prose prose-lg prose-invert mb-16 max-w-none prose-p:text-base-content/70"
            >
                <Content />
            </article>

            <Services lang={locale} />

            <div class="mb-16">
                <h2
                    class="text-2xl font-bold mb-6 border-b border-base-content/10 pb-4"
                >
                    {tPortfolio.graph.knowledgeTitle}
                </h2>
                <GraphIsland focusId={`services/${cleanId}`} lang={locale} />
            </div>

            {
                relatedProjects.length > 0 && (
                    <div class="mb-12">
                        <h2 class="text-2xl font-bold mb-6 border-b border-base-content/10 pb-4">
                            {tPortfolio.taxonomy.projectsUsingService}
                        </h2>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            {relatedProjects.map((p) => (
                                <a
                                    href={translatePath(
                                        `/projects/${p.id.replace(/\.mdx?$/, "")}`,
                                    )}
                                    class="card bg-base-200/50 hover:bg-base-200 transition-colors border border-base-content/5"
                                >
                                    <div class="card-body p-6">
                                        <h3 class="card-title text-lg">
                                            {p.data.title}
                                        </h3>
                                        <p class="text-sm opacity-70 line-clamp-2">
                                            {tPortfolio.projects.caseStudy}{" "}
                                            &rarr;
                                        </p>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </div>
                )
            }

            {
                relatedBlogs.length > 0 && (
                    <div class="mb-12">
                        <h2 class="text-2xl font-bold mb-6 border-b border-base-content/10 pb-4">
                            {tPortfolio.taxonomy.relatedArticles}
                        </h2>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            {relatedBlogs.map((b) => (
                                <a
                                    href={translatePath(
                                        `/blog/${b.id.replace(/\.mdx?$/, "")}`,
                                    )}
                                    class="card bg-base-200/50 hover:bg-base-200 transition-colors border border-base-content/5"
                                >
                                    <div class="card-body p-6">
                                        <h3 class="card-title text-lg">
                                            {b.data.title}
                                        </h3>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </div>
                )
            }
        </div>
    </main>
</Layout>

---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import { getTranslations, useTranslatedPath } from "@i18n";
import SectionHeader from "@components/ui/SectionHeader.astro";
import SearchFilters from "@components/ui/SearchFilters.astro";
import TechCard from "@components/ui/TechCard.astro";
import GraphIsland from "@components/GraphIsland.astro";

const { lang: locale } = Astro.props;
const tPortfolio = (await getTranslations(locale, "portfolio")) as Record<
    string,
    any
>;
const allTopics = await getCollection("topics");
allTopics.sort((a, b) => a.data.title.localeCompare(b.data.title));
const categories = [...new Set(allTopics.map((topic) => topic.data.category || tPortfolio.knowledge.all))].sort();
---

<Layout
    title={tPortfolio.topics.title}
    description={tPortfolio.topics.desc}
    lang={locale}
>
    <main
        class="w-full min-h-screen bg-base-100 pt-32 pb-20 px-6 lg:px-20 relative overflow-hidden"
    >
        <div class="max-w-7xl mx-auto relative z-10">
            <SectionHeader 
                label={tPortfolio.topics.title}
                title={tPortfolio.topics.title.split(' ')[0]}
                highlightedTitle={tPortfolio.topics.title.split(' ').slice(1).join(' ')}
                description={tPortfolio.topics.desc}
            />

            <SearchFilters 
                searchPlaceholder={tPortfolio.knowledge.search}
                categories={categories}
                allLabel={tPortfolio.knowledge.all}
                filterByLabel={tPortfolio.knowledge.filterBy}
                gridId="topics-grid"
                cardClass="knowledge-card"
            />

            <!-- Topics Grid -->
            <div
                class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4"
                id="topics-grid"
            >
                {
                    allTopics.map((topic) => (
                        <TechCard
                            id={topic.id}
                            title={topic.data.title}
                            description={topic.data.description}
                            icon={topic.data.icon}
                            category={topic.data.category}
                            lang={locale}
                        />
                    ))
                }
            </div>

            <div id="no-results" class="hidden text-center py-20 w-full bg-base-200/20 rounded-3xl border border-dashed border-base-content/10 mt-8">
                <p class="text-2xl font-bold opacity-30">
                    {tPortfolio.knowledge.noResults}
                </p>
                <p class="text-sm opacity-50 mt-2">
                    {tPortfolio.knowledge.tryAdjusting}
                </p>
            </div>

            <!-- Knowledge Graph Section -->
            <div class="mt-32">
                 <SectionHeader 
                    label={tPortfolio.graph.title}
                    title={tPortfolio.ui.Interactive}
                    highlightedTitle={tPortfolio.ui["Knowledge Graph"]}
                 />
                 <GraphIsland lang={locale} />
            </div>
        </div>
    </main>
</Layout>

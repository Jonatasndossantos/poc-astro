---
import { getCollection } from "astro:content";
import { getTranslations, useTranslator, useTranslatedPath } from "@i18n";
import TechCard from "@components/ui/TechCard.astro";

interface Props {
    mode: string;
    lang: string;
}

const { mode, lang } = Astro.props;
const t = (await getTranslations(lang, "portfolio")) as Record<string, any>;
const __ = await useTranslator(lang);
const translatePath = useTranslatedPath(lang);

// Fetch tags collection for skills
const allTags = await getCollection("tags");

// Pre-process skills for the current Mode
const skills = allTags
    .map((s) => ({
        id: s.id.replace(/\.mdx?$/, ""),
        title: s.data.title,
        description: s.data.description,
        icon: s.data.icon,
        category: s.data.category,
        currentRelevance: s.data.relevance?.[mode] || 0,
    }))
    .filter((s) => s.currentRelevance > 0)
    .sort((a, b) => b.currentRelevance - a.currentRelevance)
    .slice(0, 10);

// Replace %mode% with the actual mode name requested
const description = (t.skills.desc as string).replace("%mode%", mode);
---

<section id="skills" class="py-20 relative z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
            class="flex flex-col md:flex-row md:items-end justify-between mb-8 gap-4"
        >
            <div>
                <h2
                    class="text-3xl font-bold text-base-content mb-2 font-syncopate tracking-tight"
                >
                    {t.skills.title}
                </h2>
                <p class="text-base-content/60 max-w-2xl text-balance">
                    {description}
                </p>
            </div>

            <a
                href={translatePath("/ecosystem")}
                class="btn btn-outline btn-primary rounded-field group w-fit"
            >
                {__("View All")}
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 transition-transform group-hover:translate-x-1"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
            </a>
        </div>

        <div
            class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4"
        >
            {
                skills.map((skill) => (
                    <TechCard
                        id={skill.id}
                        title={skill.title}
                        description={skill.description}
                        icon={skill.icon}
                        category={skill.category}
                        lang={lang}
                    />
                ))
            }
        </div>
    </div>
</section>

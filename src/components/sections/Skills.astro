---
import { getCollection } from "astro:content";
import { getTranslations, useTranslator, useTranslatedPath } from "@i18n";
import TechCard from "@components/ui/TechCard.astro";
import SectionHeader from "@components/ui/SectionHeader.astro";

interface Props {
    mode: string;
    lang: string;
}

const { mode, lang } = Astro.props;
const t = (await getTranslations(lang, "portfolio")) as Record<string, any>;
const __ = await useTranslator(lang);
const translatePath = useTranslatedPath(lang);

// Fetch tags collection for skills
const allTags = await getCollection("tags");

// Pre-process skills for the current Mode
const skills = allTags
    .map((s) => ({
        id: s.id.replace(/\.mdx?$/, ""),
        title: s.data.title,
        description: s.data.description,
        icon: s.data.icon,
        category: s.data.category,
        currentRelevance: s.data.relevance?.[mode] || 0,
    }))
    .filter((s) => s.currentRelevance > 0)
    .sort((a, b) => b.currentRelevance - a.currentRelevance)
    .slice(0, 10);

// Replace %mode% with the actual mode name requested
const description = (t.skills.desc as string).replace("%mode%", mode);
---

<section id="skills" class="py-32 px-6 lg:px-20 relative z-10 bg-base-200/30">
    <div class="max-w-7xl mx-auto">
        <SectionHeader 
            label={t.skills.title}
            title={__("Technical")}
            highlightedTitle={__("Arsenal")}
            description={description}
            viewAllLink={translatePath("/tags")}
            viewAllLabel={__("View All")}
        />

        <div
            class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6"
        >
            {
                skills.map((skill) => (
                    <TechCard
                        id={skill.id}
                        title={__ (skill.title)}
                        description={__ (skill.description)}
                        icon={skill.icon}
                        category={skill.category}
                        lang={lang}
                    />
                ))
            }
        </div>
    </div>
</section>

---
import { getTranslations, useTranslator } from "@i18n";
import { Image } from "astro:assets";
import SectionHeader from "@components/ui/SectionHeader.astro";

interface Props {
    lang: string;
}

const { lang } = Astro.props;

const t = (await getTranslations(lang, "portfolio")) as Record<string, any>;
const __ = await useTranslator(lang);

const timeline = t.about?.timeline || [];
---

<section id="timeline" class="py-32 px-6 lg:px-20 relative z-10 bg-base-200/50">
    <div class="max-w-7xl mx-auto">
        
        <div class="flex flex-col lg:flex-row gap-16 items-start">
            
            <!-- Sticky Photo Placeholder for Timeline -->
            <div class="w-full lg:w-1/3 flex flex-col items-center sticky top-32 shrink-0">
                <div class="relative w-64 h-64 md:w-80 md:h-80">
                    <!-- Foto circular com os estilos modernos de borda.
                         Para testar outra foto, substitua a url do src abaixo! -->
                    <div class="absolute inset-0 rounded-full border border-base-content/10 animate-[spin_10s_linear_infinite]"></div>
                    <div class="absolute -inset-4 rounded-full border border-primary/20 animate-[spin_15s_linear_infinite_reverse]"></div>
                    <div class="w-full h-full rounded-full overflow-hidden border-2 border-base-content/10 shadow-2xl grayscale hover:grayscale-0 transition-all duration-500">
                        <Image
                            src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=800"
                            alt={__("Journey")}
                            width={400}
                            height={400}
                            loading="lazy"
                            class="w-full h-full object-cover"
                        />
                    </div>
                </div>
                
                <div class="mt-12 text-center">
                    <h3 class="text-3xl font-bold font-syncopate mb-2">{t.about?.timelineTitle || __("My Journey")}</h3>
                    <p class="text-base-content/60 max-w-sm text-balance">{t.about?.timelineSubtitle || __("A brief history of my career.")}</p>
                </div>
            </div>

            <!-- The Timeline -->
            <div class="w-full lg:w-2/3">
                <ul class="timeline timeline-snap-icon max-md:timeline-compact timeline-vertical w-full">
                    {timeline.map((item: any, index: number) => {
                        const isEven = index % 2 === 0;
                        return (
                            <li>
                                {index !== 0 && <hr class="bg-primary/20" />}
                                <div class="timeline-middle">
                                    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-primary">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                                    </svg>
                                </div>
                                <div class={`mb-12 pt-2 ${isEven ? 'timeline-start md:text-right md:pr-8' : 'timeline-end md:pl-8'} group`}>
                                    <div class="w-full md:max-w-md">
                                        <time class="font-mono text-sm text-primary mb-2 block">{item.date}</time>
                                        <h4 class="text-xl md:text-2xl font-black mb-3 text-base-content group-hover:text-primary transition-colors">{item.title}</h4>
                                        <p class="text-base-content/70 text-base leading-relaxed" set:html={item.desc}></p>
                                    </div>
                                </div>
                                {index !== timeline.length - 1 && <hr class="bg-primary/20" />}
                            </li>
                        )
                    })}
                </ul>
            </div>
            
        </div>

    </div>
</section>

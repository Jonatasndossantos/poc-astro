---
import { getCollection } from "astro:content";
import { useTranslator, useTranslatedPath } from "@i18n";
import SectionHeader from "@components/ui/SectionHeader.astro";
import ProjectCard from "@components/ui/ProjectCard.astro";

interface Props {
    mode?: string;
    lang: string;
    projects?: any[];
}

const { lang, projects } = Astro.props;
const __ = await useTranslator(lang);
const translatePath = useTranslatedPath(lang);

// Fetch dynamic projects from content collection
const allProjects = await getCollection("projects");

// Pre-process projects for consistent card mapping
const projectsData = projects || allProjects.slice(0, 6).map((p) => {
    const cleanId = p.id.replace(/\.mdx?$/, "");
    return {
        id: cleanId,
        title: p.data.title,
        imageUrl: p.data.heroImage || "",
        demoUrl: p.data.demoUrl,
        repoUrl: p.data.repoUrl,
        technologies: p.data.tags
            ? p.data.tags.map((t: any) => ({
                  id: (t.id || t).replace(/\.mdx?$/, ""),
                  name: (t.id || t).split('/').pop()?.replace(/-/g, " ") || "Tech",
              }))
            : [],
        description: p.data.description || "",
    };
});
---

<section id="projects" class="py-32 px-6 lg:px-20 relative bg-base-100 overflow-hidden">
    <div class="max-w-7xl mx-auto">
        <SectionHeader 
            label={__("Design & Dev")}
            title={__("Featured")}
            highlightedTitle={__("Projects")}
            viewAllLink={translatePath("/projects")}
            viewAllLabel={__("View All")}
        />

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                projectsData.map((project, index) => {
                    const isFeatured = index === 0 || index === 3;
                    return (
                        <ProjectCard 
                            project={project}
                            lang={lang}
                            isFeatured={isFeatured}
                            caseStudyLabel={__("Read Case Study")}
                            viewProjectLabel={__("Live Demo")}
                            codeLabel={__("Source Code")}
                        />
                    );
                })
            }
        </div>
    </div>
</section>

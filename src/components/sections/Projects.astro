---
import { getCollection } from "astro:content";
import { getTranslations, useTranslatedPath } from "@i18n";
import SectionHeader from "@components/ui/SectionHeader.astro";
import ProjectCard from "@components/ui/ProjectCard.astro";

interface Props {
    mode: string;
    lang: string;
}

const { mode, lang } = Astro.props;
const t = (await getTranslations(lang, "portfolio")) as Record<string, any>;
const translatePath = useTranslatedPath(lang);

// Fetch dynamic projects from content collection
const allProjects = await getCollection("projects");

// Pre-process projects for consistent card mapping
const projectsData = allProjects.slice(0, 6).map((p) => {
    const cleanId = p.id.replace(/\.mdx?$/, "");
    return {
        id: cleanId,
        title: p.data.title,
        imageUrl: p.data.heroImage || "",
        demoUrl: p.data.demoUrl,
        repoUrl: p.data.repoUrl,
        technologies: p.data.tags
            ? p.data.tags.map((t: any) => ({
                  id: (t.id || t).replace(/\.mdx?$/, ""),
                  name: (t.id || t).split('/').pop()?.replace(/-/g, " ") || "Tech",
              }))
            : [],
        displayDescriptionTextKey: `projects.items.${cleanId}.description.${mode}`,
    };
});
---

<section id="projects" class="py-32 px-6 lg:px-20 relative bg-base-100 overflow-hidden">
    <div class="max-w-7xl mx-auto">
        <SectionHeader 
            label={t.projects.label}
            title={t.projects.title}
            highlightedTitle={t.projects.highlightedTitle}
            viewAllLink={translatePath("/projects")}
            viewAllLabel={t.projects.title}
        />

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                projectsData.map((project) => (
                    <ProjectCard 
                        project={project}
                        lang={lang}
                        caseStudyLabel={t.projects.caseStudy}
                        viewProjectLabel={t.projects.viewProject}
                        codeLabel={t.projects.code}
                    />
                ))
            }
        </div>
    </div>
</section>

---
import { useTranslator } from "@i18n";

interface Props {
    focusId?: string;
    lang?: string;
}

const { focusId, lang = "en" } = Astro.props;
const __ = await useTranslator(lang);
---

<div
    class="w-full h-[500px] border border-base-content/10 rounded-2xl bg-[#0f172a] overflow-hidden relative"
    id="graph-wrapper"
    data-focus={focusId}
>
    <!-- We force a dark slate background for the graph `#0f172a` so the explicit colors always pop perfectly -->
    <div id="graph-container" class="w-full h-full"></div>
    <div
        class="absolute bottom-4 right-4 bg-slate-900/80 rounded-lg p-3 text-xs opacity-90 shadow-lg pointer-events-none text-slate-200 border border-slate-700/50"
    >
        <ul class="space-y-1">
            <li class="flex items-center">
                <span
                    class="inline-block w-3 h-3 rounded-full bg-[#0ea5e9] border border-[#0369a1] mr-2"
                ></span> {__("Projects")}
            </li>
            <li class="flex items-center">
                <span
                    class="inline-block w-3 h-3 rounded-full bg-[#ef4444] border border-[#b91c1c] mr-2"
                ></span> {__("Blog")}
            </li>
            <li class="flex items-center">
                <span
                    class="inline-block w-3 h-3 rounded-full bg-[#9ca3af] border border-[#4b5563] mr-2"
                ></span> {__("Services")}
            </li>
            <li class="flex items-center">
                <span
                    class="inline-block w-3 h-3 rounded-full bg-[#a855f7] border border-[#7e22ce] mr-2"
                ></span> {__("Topics")}
            </li>
            <li class="flex items-center">
                <span
                    class="inline-block w-3 h-3 rounded-full bg-[#f97316] border border-[#c2410c] mr-2"
                ></span> {__("Tags")}
            </li>
        </ul>
    </div>
</div>

<script>
    import * as d3 from "d3";

    async function initGraph() {
        const wrapper = document.getElementById("graph-wrapper");
        const focusId = wrapper?.dataset.focus;
        const query = focusId ? `&focus=${focusId}` : "";

        // Cache bust the JSON payload so Astro/Browsers don't hang on to the broken version
        const res = await fetch(
            `/graph.json?v=${new Date().getTime()}${query}`,
        );
        if (!res.ok) return;
        const data = await res.json();

        const container = document.getElementById("graph-container");
        if (!container) return;
        container.innerHTML = ""; // Clear existing on SPA load

        const width = container.clientWidth;
        const height = container.clientHeight;

        // 🎨 CORES DOS NÓS (LEGENDA E GRUPOS)
        // Mude o "fill" ou "stroke" para customizar o tema!
        const colorMap: Record<string, { fill: string; stroke: string }> = {
            projects: { fill: "#0ea5e9", stroke: "#0369a1" }, // Azul Claro
            blog: { fill: "#ef4444", stroke: "#b91c1c" }, // Vermelho
            services: { fill: "#9ca3af", stroke: "#4b5563" }, // Cinza Claro
            topics: { fill: "#a855f7", stroke: "#7e22ce" }, // Roxo
            tags: { fill: "#f97316", stroke: "#c2410c" }, // Laranja
            unknown: { fill: "#64748b", stroke: "#334155" }, // Slate Escuro
        };

        // 🎛️ CUSTOMIZAÇÃO DA FÍSICA E SEPARAÇÃO DE GRUPOS
        const repelForce = 0.8; // Força base de repulsão
        const linkDistance = 50; // Tamanho das linhas comuns (satélites em volta do núcleo)
        const gravity = 0.1; // Força do ímã de grupo

        // 🗺️ ZONAS MAGNÉTICAS (Atrai os componentes para cantos específicos)
        const getZone = (group: string) => {
            switch (group) {
                case "projects": return { x: width * 0.25, y: height * 0.25 }; // Canto Superior Esquerdo
                case "blog": return { x: width * 0.75, y: height * 0.25 };     // Canto Superior Direito
                case "topics": return { x: width * 0.25, y: height * 0.75 };   // Canto Inferior Esquerdo
                case "services": return { x: width * 0.75, y: height * 0.75 }; // Canto Inferior Direito
                default: return { x: width * 0.5, y: height * 0.5 };           // Tags no Centro
            }
        };

        // 🔴 TAMANHO DAS BOLINHAS (Nodes)
        const nodeRadius = (d: any) => {
            const weight = d.weight || 0;
            return 3 + Math.sqrt(weight) * 1.5;
        };

        // Create simulation (Motor Físico D3)
        const simulation = d3
            .forceSimulation(data.nodes)
            // 💨 Repulsão Variável: Grandes "Hubs" se repelem MUITO mais forte do que bolinhas pequenas
            .force("charge", d3.forceManyBody().strength((d: any) => {
                const weight = d.weight || 0;
                return -150 * repelForce - (weight * 25 * repelForce);
            }))
            // 🔗 Ligações: Hubs empurram outros Hubs pra longe (linhas grandes). Folhas ficam perto (linhas curtas).
            .force(
                "link",
                d3
                    .forceLink(data.links)
                    .id((d: any) => d.id)
                    .distance((l: any) => {
                        // l.source e l.target num momento inicial já são convertidos em nós pelo d3, mas o TS pode chiar.
                        // Usamos um fallback caso as instâncias não estiverem prontas.
                        const w1 = typeof l.source === 'object' ? (l.source.weight || 0) : 0;
                        const w2 = typeof l.target === 'object' ? (l.target.weight || 0) : 0;
                        
                        // Se um nó grande tenta abraçar outro nó grande, a linha estica violentamente 
                        if (w1 > 4 && w2 > 4) {
                            return linkDistance * 3 + (w1 + w2) * 5; 
                        }
                        return linkDistance;
                    }),
            )
            // 📍 Centro Dinâmico
            .force("center", d3.forceCenter(width / 2, height / 2))
            // 🧲 Gravidade Zonal: Força as categorias a formarem "Clãs" em seus respectivos cantos 
            .force("x", d3.forceX((d: any) => getZone(d.group).x).strength(gravity))
            .force("y", d3.forceY((d: any) => getZone(d.group).y).strength(gravity))
            // 🛡️ Colisão: Impede fisicamente que as bolinhas entrem umas nas outras
            .force(
                "collide",
                d3.forceCollide().radius((d: any) => nodeRadius(d) + 12), // Margem levemente maior pra não embolar textos
            );

        const svg = d3
            .select("#graph-container")
            .append("svg")
            .attr("width", "100%")
            .attr("height", "100%")
            .call(
                d3
                    .zoom<SVGSVGElement, unknown>()
                    .scaleExtent([0.25, 4])
                    .on("zoom", (e) => {
                        svgGroup.attr("transform", e.transform);
                    }) as any,
            )
            .append("g");

        const svgGroup = svg;

        // 🕸️ ESTILO DAS LINHAS (ARESTAS)
        const link = svgGroup
            .append("g")
            .selectAll("line")
            .data(data.links)
            .join("line")
            .attr("stroke", "#334155") // Fainter slate for minimalist look (Cor em repouso)
            .attr("stroke-width", 1)   // Espessura do traço
            .attr("stroke-opacity", 0.4); // O quão transparentes as linhas serão

        // Draw Nodes
        const node = svgGroup
            .append("g")
            .selectAll("g.node-group")
            .data(data.nodes)
            .join("g")
            .attr("class", "node-group")
            .style("cursor", (d: any) => (d.hasRoute ? "pointer" : "default"))
            .style("transition", "opacity 0.2s ease")
            .on("click", (_event: any, d: any) => {
                if (!d.hasRoute) return;
                
                // Better locale detection
                const pathParts = window.location.pathname.split("/").filter(Boolean);
                const supportedLocales = ["pt", "fr", "es", "zh", "ja"]; 
                const locale = supportedLocales.includes(pathParts[0]) ? pathParts[0] : "";
                
                window.location.href = locale ? `/${locale}/${d.id}` : `/${d.id}`;
            })
            .on("mouseover", function (_event: any, d: any) {
                // Dim all nodes except connected
                node.style("opacity", (n: any) => {
                    const isConnected = data.links.some((l: any) => 
                        (l.source.id === d.id && l.target.id === n.id) ||
                        (l.target.id === d.id && l.source.id === n.id)
                    );
                    return isConnected || n.id === d.id ? 1 : 0.15;
                });

                // Highlight Node Circle
                d3.select(this)
                    .select("circle")
                    .attr("stroke", "#fff")
                    .attr("stroke-width", 2);

                // Highlight Labels
                node.selectAll("text")
                    .style("fill", (n: any) => {
                        const isConnected = data.links.some((l: any) => 
                            (l.source.id === d.id && l.target.id === n.id) ||
                            (l.target.id === d.id && l.source.id === n.id)
                        );
                        return isConnected || n.id === d.id ? "#f8fafc" : "#64748b";
                    })
                    .style("font-weight", (n: any) => {
                        const isConnected = data.links.some((l: any) => 
                            (l.source.id === d.id && l.target.id === n.id) ||
                            (l.target.id === d.id && l.source.id === n.id)
                        );
                        return isConnected || n.id === d.id ? "600" : "400";
                    });

                // Highlight connected edges
                link.attr("stroke", (l: any) =>
                    l.source.id === d.id || l.target.id === d.id
                        ? "#94a3b8"
                        : "#1e293b",
                )
                    .attr("stroke-width", (l: any) =>
                        l.source.id === d.id || l.target.id === d.id ? 2 : 1,
                )
                    .attr("stroke-opacity", (l: any) =>
                        l.source.id === d.id || l.target.id === d.id ? 1 : 0.05,
                    );
            })
            .on("mouseout", function (_event: any, d: any) {
                // Remove highlight from Node Circle
                d3.select(this)
                    .select("circle")
                    .attr("stroke-width", 1.5)
                    .attr(
                        "stroke",
                        colorMap[d.group]?.stroke || colorMap.unknown.stroke,
                    );

                // Reset nodes
                node.style("opacity", 1);

                // Reset labels
                node.selectAll("text")
                    .style("fill", "#64748b")
                    .style("font-weight", (n: any) => n.weight > 5 ? "500" : "400");

                // Reset edges
                link.attr("stroke", "#334155")
                    .attr("stroke-width", 1)
                    .attr("stroke-opacity", 0.4);
            })
            .call(drag(simulation) as any);

        // Draw Circles inside node
        node.append("circle")
            .attr("r", nodeRadius)
            .attr(
                "fill",
                (d: any) => colorMap[d.group]?.fill || colorMap.unknown.fill,
            )
            .attr(
                "stroke",
                (d: any) =>
                    colorMap[d.group]?.stroke || colorMap.unknown.stroke,
            )
            .attr("stroke-width", 1.5);

        // 🖼️ ICONS (NEW!)
        node.append("image")
            .attr("href", (d: any) => d.icon)
            .attr("x", (d: any) => -nodeRadius(d) / 1.5)
            .attr("y", (d: any) => -nodeRadius(d) / 1.5)
            .attr("width", (d: any) => nodeRadius(d) * 1.33)
            .attr("height", (d: any) => nodeRadius(d) * 1.33)
            .attr("preserveAspectRatio", "xMidYMid slice")
            .style("pointer-events", "none");

        // 🔤 ESTILO DOS TEXTOS (RÓTULOS)
        node.append("text")
            .attr("text-anchor", "middle")
            .attr("dy", (d: any) => nodeRadius(d) + 12) // Espaçamento (Distância do raio de cima pra baixo)
            .attr("font-size", (d: any) =>
                d.weight > 5 ? "11px" : "9px", // Tamanho se for Bolinha Grande vs Pequena
            )
            .attr("font-weight", (d: any) =>
                d.weight > 5 ? "500" : "400",  // Negrito se a bolinha for principal
            )
            .style("fill", "#64748b") // Dimmed text by default (Cor em repouso)
            .style("opacity", (d: any) => d.weight > 2 ? 0.9 : 0.4) // Esconde ou borra palavras secundárias
            .style("pointer-events", "none")
            .style("user-select", "none")
            .text((d: any) => d.label);

        node.append("title").text((d: any) => `${d.label} (${d.group})`);

        // Animation tick
        simulation.on("tick", () => {
            link.attr("x1", (d: any) => d.source.x)
                .attr("y1", (d: any) => d.source.y)
                .attr("x2", (d: any) => d.target.x)
                .attr("y2", (d: any) => d.target.y);

            node.attr("transform", (d: any) => `translate(${d.x},${d.y})`);
        });

        // Drag functions
        function drag(simulation: any) {
            function dragstarted(event: any) {
                if (!event.active) simulation.alphaTarget(0.3).restart();
                event.subject.fx = event.subject.x;
                event.subject.fy = event.subject.y;
            }
            function dragged(event: any) {
                event.subject.fx = event.x;
                event.subject.fy = event.y;
            }
            function dragended(event: any) {
                if (!event.active) simulation.alphaTarget(0);
                event.subject.fx = null;
                event.subject.fy = null;
            }
            return d3
                .drag()
                .on("start", dragstarted)
                .on("drag", dragged)
                .on("end", dragended);
        }
    }

    document.addEventListener("DOMContentLoaded", initGraph);
    document.addEventListener("astro:page-load", initGraph);
</script>

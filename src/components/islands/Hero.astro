---
import { getTranslations, useTranslator } from "@i18n";

import { Image } from "astro:assets";
import bgFallback from "../../assets/Underwater Transition@1-1920x919.png";

/**
 * Hero receives pre-resolved, locale+mode-aware strings from the Astro parent.
 * No i18n logic here — pure rendering.
 *
 * The Astro parent does:
 *   <Hero bio={profile.bio[mode]} role={profile.role[mode]} ... />
 */

const { lang, mode } = Astro.props;
const profile = (await getTranslations(lang, "profile")) as Record<string, any>;
const __ = await useTranslator(lang);
---

<script>
    import { Application } from "@splinetool/runtime";

    const canvas = document.getElementById("canvas3d") as HTMLCanvasElement;

    // --- CONSOLE CLEANUP ---
    // Filter out noisy THREE.js/Spline shader warnings (unroll optimizations)
    const originalWarn = console.warn;
    const filterShaderWarning =
        (method: typeof originalWarn) =>
        (...args: any[]) => {
            if (
                args[0] &&
                typeof args[0] === "string" &&
                args[0].includes("X3557")
            )
                return;
            method.apply(console, args);
        };
    console.warn = filterShaderWarning(originalWarn);
    // -----------------------

    if (canvas) {
        let app: Application | null = null;
        let isLoaded = false;

        const initSpline = () => {
            if (isLoaded) return;
            isLoaded = true;
            app = new Application(canvas);
            app.load(
                "https://prod.spline.design/LemjWKcGZtc47q1C/scene.splinecode",
            ).then(() => {
                if (app) {
                    try {
                        app.setBackgroundColor("transparent");
                    } catch (e) {
                        console.warn(
                            "Spline Background Transparency Error:",
                            e,
                        );
                    }
                }
                canvas.classList.remove("opacity-0");
                const fallback = document.getElementById("spline-fallback");
                if (fallback) fallback.classList.add("opacity-0");
            });
        };

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        if (!isLoaded) {
                            // Delay drastically to prioritize LCP and main thread interactions
                            if ("requestIdleCallback" in window) {
                                (window as any).requestIdleCallback(
                                    initSpline,
                                    { timeout: 2000 },
                                );
                            } else {
                                setTimeout(initSpline, 1500);
                            }
                        } else if (app) {
                            try {
                                if (typeof (app as any).play === "function")
                                    (app as any).play();
                            } catch (e) {
                                console.warn("Spline Play Error:", e);
                            }
                        }
                    } else {
                        if (app) {
                            try {
                                if (typeof (app as any).stop === "function")
                                    (app as any).stop();
                            } catch (e) {
                                console.warn("Spline Stop Error:", e);
                            }
                        }
                    }
                });
            },
            { threshold: 0 },
        );

        observer.observe(canvas);
    }
</script>

<section
    class="relative min-h-screen w-full flex flex-col justify-center px-6 lg:px-20 overflow-hidden pt-32 pb-20"
>
    <div class="absolute inset-0 hero-parallax">
        <Image
            id="spline-fallback"
            src={bgFallback}
            alt={__("Hero Background")}
            class="absolute inset-0 w-full h-full object-cover transition-opacity duration-1000"
            loading="eager"
            fetchpriority="high"
        />
        <canvas
            id="canvas3d"
            class="absolute inset-0 w-full h-full border-0 transition-opacity duration-1000 opacity-0"
        ></canvas>
    </div>

    <div
        class="absolute inset-0 bg-linear-to-t from-base-100 via-base-100/40 to-transparent pointer-events-none"
    >
    </div>

    <header
        class="z-10 relative w-full max-w-4xl hero-parallax text-left flex flex-col justify-center"
    >
        <div class="overflow-hidden">
            <h1
                class="text-6xl md:text-8xl font-bold leading-tight tracking-tighter mb-2 text-balance break-keep"
                data-gsap="hero-title"
            >
                {profile.greeting}
            </h1>
        </div>

        <div class="overflow-hidden">
            <h2
                class="opacity-80 text-4xl md:text-5xl font-light mb-8 text-balance break-keep"
                data-gsap="hero-role"
            >
                {profile.modes[mode].role}
            </h2>
        </div>

        <div class="overflow-hidden">
            <div
                class="text-2xl md:text-3xl font-medium mb-8 flex flex-wrap gap-2 items-center"
                data-gsap="hero-rotating-text"
            >
                <span>{profile.providingSolutionsFor}</span>
                <span
                    class="text-rotate h-10 inline-block overflow-hidden align-bottom"
                >
                    <span class="flex flex-col text-left">
                        <span class="text-secondary h-10"
                            >{profile.developers}</span
                        >
                        <span class="text-primary h-10">{profile.managers}</span
                        >
                        <span class="text-accent h-10">{profile.designers}</span
                        >
                    </span>
                </span>
            </div>
        </div>

        <div class="overflow-hidden">
            <p
                class="text-lg md:text-xl max-w-xl leading-relaxed mb-10 text-pretty opacity-80 break-keep"
                data-gsap="hero-bio"
            >
                {profile.modes[mode].bio}
            </p>
        </div>
    </header>

    <div
        class="absolute bottom-10 right-10 hidden md:block animate-bounce pointer-events-none"
    >
        <div
            class="text-xs z-10 font-mono opacity-50 rotate-90 origin-bottom-right tracking-widest"
        >
            {profile.scroll}
        </div>
    </div>

    <!-- Lower Transition Shadow Shadow -->
    <div
        class="absolute bottom-0 left-0 w-full h-60 bg-linear-to-t from-base-100 to-transparent pointer-events-none"
    >
    </div>
</section>

---
import ThemeToggle from "../ui/ThemeToggle.astro";
import LanguageToggle from "./LanguageToggle.astro";
import { useTranslator, useTranslatedPath } from "@i18n";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

const navLinks = [
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects" },
    { label: "Services", href: "/services" },
    { label: "Blog", href: "/blog" },
];

const navName = "SANTOS";
const navPrefix = ".DEV";

const iconLinks = [
    {
        label: "GitHub",
        href: "https://github.com/jonatasndossantos",
        icon: "simple-icons:github",
    },
];

const { lang } = Astro.props;
const translatePath = useTranslatedPath(lang);
const __ = await useTranslator(lang);

// Logic to determine active link
const currentPath = Astro.url.pathname;
const isHome =
    currentPath === "/" ||
    currentPath === `/${lang}/` ||
    currentPath === `/${lang}`;
---

<header
    class="fixed top-6 left-0 right-0 z-50 flex justify-center px-4 pointer-events-none"
>
    <div
        class="navbar w-full max-w-5xl h-16 bg-base-100/60 backdrop-blur-2xl border border-base-content/10 px-6 rounded-3xl shadow-[0_8px_32px_rgba(0,0,0,0.1)] pointer-events-auto transition-colors duration-500 ease-out hover:border-primary/20"
    >
        <input
            id="nav-drawer"
            type="checkbox"
            class="drawer-toggle"
            aria-label="Toggle Navigation"
        />
        <!-- Brand / Logo -->
        <div class="navbar-start w-auto lg:w-1/2 flex items-center gap-4">
            <a
                href={translatePath("/")}
                class="flex items-center gap-3 group"
                aria-label={`${navName} ${navPrefix}`}
            >
                <div class="relative flex items-center justify-center size-9">
                    <div
                        class="absolute inset-0 bg-primary/20 rounded-xl blur-lg group-hover:bg-primary/40 transition-colors"
                    >
                    </div>
                    <Image
                        src="/favicon.svg"
                        alt="Logo"
                        width={30}
                        height={30}
                        loading="eager"
                        class="size-7 relative z-10 transition-transform group-hover:rotate-12 group-hover:scale-110"
                        aria-hidden="true"
                    />
                </div>
                <div class="flex-col">
                    <span
                        class="font-bold text-sm tracking-widest text-base-content leading-none"
                    >
                        {navName}<span class="text-primary">{navPrefix}</span>
                    </span>
                    <span
                        class="hidden sm:flex text-[9px] font-medium opacity-40 uppercase tracking-[0.2em] -mt-0.5 whitespace-nowrap"
                    >
                        {__("Software Architect")}
                    </span>
                </div>
            </a>
        </div>

        <!-- Desktop Navigation -->
        <div class="navbar-center hidden lg:flex">
            <div
                class="flex items-center bg-base-content/5 p-1 rounded-2xl border border-base-content/5"
            >
                {
                    navLinks.map((link) => {
                        const href = translatePath(link.href);
                        const isActive =
                            (link.href === "/" && isHome) ||
                            (link.href !== "/" &&
                                currentPath.includes(link.href));

                        return (
                            <a
                                href={href}
                                class:list={[
                                    "px-5 py-2 text-[11px] font-bold uppercase tracking-widest rounded-xl transition-all duration-300 relative group",
                                    isActive
                                        ? "text-primary-content bg-primary shadow-lg shadow-primary/20"
                                        : "text-base-content/60 hover:text-base-content hover:bg-base-content/5",
                                ]}
                            >
                                {__(link.label)}
                                {isActive && (
                                    <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-1.5 h-1.5 bg-primary rounded-full blur-[2px] opacity-50" />
                                )}
                            </a>
                        );
                    })
                }
            </div>
        </div>

        <!-- Search & Actions -->
        <div
            class="navbar-end w-auto lg:w-1/2 flex items-center gap-2 lg:justify-end ml-auto"
        >
            <a
                href={translatePath("/tags")}
                class="btn btn-ghost btn-sm btn-circle text-base-content/60 hover:text-primary transition-colors hidden sm:flex"
                aria-label={__("search")}
                title={__("search")}
            >
                <Icon name="lucide:brain" class="size-5" />
            </a>

            <div
                class="hidden md:flex items-center gap-2 border-l border-base-content/10 pl-2 ml-2"
            >
                <ThemeToggle locale={lang} />
                <LanguageToggle currentLocale={lang} />
            </div>

            <!-- Mobile Menu Trigger -->
            <button
                type="button"
                onclick="document.getElementById('nav-drawer').click()"
                aria-label={__("Open Menu")}
                class="btn btn-square btn-ghost"
            >
                <Icon name="lucide:menu" class="size-5" />
            </button>
        </div>
    </div>
</header>

---
import ThemeToggle from "../ui/ThemeToggle.astro";
import LanguageToggle from "./LanguageToggle.astro";
import { useTranslator, useTranslatedPath } from "@i18n";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

const navLinks = [
    { label: "Home", href: "/" },
    { label: "Projects", href: "/projects" },
    { label: "Services", href: "/services" },
    { label: "Blog", href: "/blog" },
];

const navName = "SANTOS";
const navPrefix = ".DEV";

const iconLinks = [
    {
        label: "GitHub",
        href: "https://github.com/jonatasndossantos",
        icon: "simple-icons:github",
    },
];

const { lang } = Astro.props;
const translatePath = useTranslatedPath(lang);
const __ = await useTranslator(lang);

// Logic to determine active link
const currentPath = Astro.url.pathname;
const isHome =
    currentPath === "/" ||
    currentPath === `/${lang}/` ||
    currentPath === `/${lang}`;
---

<header
    class="fixed top-6 left-0 right-0 z-20 flex justify-center px-4 pointer-events-none"
>
    <div
        class="navbar w-full max-w-5xl h-16 bg-base-100/70 backdrop-blur-sm border border-base-content/10 px-6 rounded-[calc(var(--radius-box)*2)] shadow-xl pointer-events-auto transition-colors duration-500 ease-out hover:border-primary/20"
    >
        <!-- Brand / Logo -->
        <div class="navbar-start w-auto lg:w-1/2 flex items-center gap-4">
            <a
                href={translatePath("/")}
                class="flex items-center gap-3 group"
                aria-label={`${navName} ${navPrefix}`}
            >
                <div class="relative flex items-center justify-center size-9">
                    <div
                        class="absolute inset-0 bg-primary/20 rounded-box blur-lg group-hover:bg-primary/40 transition-colors"
                    >
                    </div>
                    <Image
                        src="/favicon.svg"
                        alt="Logo"
                        width={30}
                        height={30}
                        loading="eager"
                        class="size-7 relative z-10 transition-transform group-hover:rotate-12 group-hover:scale-110"
                        aria-hidden="true"
                    />
                </div>
                <div class="flex-col">
                    <span
                        class="font-bold text-sm tracking-widest text-base-content leading-none"
                    >
                        {navName}<span class="text-primary">{navPrefix}</span>
                    </span>
                    <span
                        class="hidden sm:flex text-[9px] font-medium opacity-40 uppercase tracking-[0.2em] -mt-0.5 whitespace-nowrap"
                    >
                        {__("Software Architect")}
                    </span>
                </div>
            </a>
        </div>

        <!-- Search & Actions -->
        <div
            class="navbar-end w-auto lg:w-1/2 flex items-center gap-2 lg:justify-end ml-auto"
        >
            <a
                href={translatePath("/tags")}
                class="btn btn-ghost btn-sm btn-circle text-base-content/60 hover:text-primary transition-colors hidden sm:flex"
                aria-label={__("search")}
                title={__("search")}
            >
                <Icon name="lucide:search" class="size-5" aria-hidden="true" />
            </a>

            <div
                class="hidden md:flex items-center gap-2 border-l border-base-content/10 pl-2 ml-2"
            >
                <ThemeToggle locale={lang} />
                <LanguageToggle currentLocale={lang} />
            </div>

            <!-- Mobile Menu Trigger -->
            <button
                type="button"
                onclick="document.getElementById('mobile-menu').click()"
                aria-label={__("Open Menu")}
                class="btn btn-square btn-ghost"
            >
                <Icon name="lucide:menu" class="size-5" aria-hidden="true" />
            </button>
        </div>
    </div>
</header>

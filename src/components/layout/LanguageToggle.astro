---
import { getRelativeLocaleUrl } from "astro:i18n";
import {
    locales,
    nativeNames,
    getPathWithoutLocale,
    defaultLocale,
} from "@i18n";
import { getTranslations, useTranslator } from "@i18n";
import { Icon } from "astro-icon/components";

interface Props {
    currentLocale?: string;
    class?: string;
}

const { currentLocale = defaultLocale, class: className } = Astro.props;

const currentPath = getPathWithoutLocale(Astro.url.pathname);

const langDict = (await getTranslations(currentLocale, "language")) as Record<
    string,
    string
>;
const __ = await useTranslator(currentLocale);
---

<div
    class:list={[
        "dropdown dropdown-end sm:dropdown-bottom dropdown-top group",
        className,
    ]}
>
    <!-- Accessible Trigger Button -->
    <button
        type="button"
        tabindex="0"
        class="btn btn-sm btn-ghost gap-2 px-3 rounded-xl border border-base-content/5 hover:border-primary/30 transition-all hover:bg-base-content/5"
        aria-label={__("Change Language")}
        title={__("Change Language")}
    >
        <div class="relative flex items-center justify-center p-0.5">
            <Icon
                name="lucide:globe"
                class="size-5 opacity-60 group-hover:opacity-100 group-hover:text-primary transition-all duration-300 transform group-hover:rotate-12"
                aria-hidden="true"
            />
            <span
                class="absolute -bottom-1 -right-2 uppercase font-black text-[7px] leading-none tracking-tighter opacity-70 bg-primary text-primary-content rounded-[3px] px-1 py-0.5 shadow-sm border border-black/10"
                >{currentLocale}</span
            >
        </div>
        <span class="text-[10px] font-bold uppercase tracking-widest opacity-60 hidden xl:inline-block">
            {langDict["label"] || __("Language")}
        </span>
        <svg
            width="10px"
            height="10px"
            class="fill-current opacity-40 transition-transform group-focus-within:rotate-180"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 2048 2048"
        >
            <path d="M1799 349l242 241-1017 1017L7 590l242-241 775 775 775-775z"></path>
        </svg>
    </button>

    <!-- Dropdown Content with Glassmorphism -->
    <div
        tabindex="0"
        class="dropdown-content mt-4 p-3 bg-base-100/80 backdrop-blur-2xl border border-base-content/10 shadow-2xl rounded-3xl w-60 max-h-[60vh] overflow-y-auto scrollbar-hide z-[100] animate-in fade-in zoom-in-95 duration-200"
    >
        <div class="px-2 pb-3 mb-2 border-b border-base-content/5 flex items-center justify-between">
             <span class="text-[10px] font-black uppercase tracking-[0.2em] opacity-30">
                {langDict["label"] || __("Language")}
             </span>
             <Icon name="lucide:languages" class="size-3 opacity-20" />
        </div>
        
        <ul class="flex flex-col gap-1">
            {locales.map((locale) => (
                <li>
                    <a
                        href={getRelativeLocaleUrl(locale, currentPath)}
                        data-locale-link={locale}
                        class:list={[
                            "w-full flex items-center justify-between p-3 rounded-xl transition-all group/item",
                            currentLocale === locale 
                                ? "bg-primary text-primary-content shadow-lg shadow-primary/20" 
                                : "text-sm font-medium hover:bg-primary/10 hover:text-primary"
                        ]}
                    >
                        <div class="flex flex-col gap-0.5 overflow-hidden">
                             <span class="font-bold tracking-tight capitalize truncate">
                                {nativeNames[locale as keyof typeof nativeNames] || locale}
                             </span>
                             <span class:list={[
                                 "text-[10px] uppercase font-bold tracking-widest",
                                 currentLocale === locale ? "opacity-80" : "opacity-40"
                             ]}>
                                {langDict[locale] || locale}
                             </span>
                        </div>
                        
                        {currentLocale === locale ? (
                            <Icon name="lucide:check-circle" class="size-4 animate-in zoom-in spin-in-12" />
                        ) : (
                            <Icon name="lucide:chevron-right" class="size-3 opacity-0 group-hover/item:opacity-40 transition-all -translate-x-2 group-hover/item:translate-x-0" />
                        )}
                    </a>
                </li>
            ))}
        </ul>
    </div>
</div>

<script>
    function setupLangLinks() {
        document.querySelectorAll("[data-locale-link]").forEach((link) => {
            link.addEventListener("click", () => {
                const locale = link.getAttribute("data-locale-link");
                if (locale) {
                    localStorage.setItem("preferred-locale", locale);
                }
            });
        });
    }

    document.addEventListener("astro:page-load", setupLangLinks);
    setupLangLinks();
</script>

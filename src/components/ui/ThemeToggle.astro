---
import { getTranslations, useTranslator } from "@i18n";
export interface Props {
    locale?: string;
    class?: string;
    dropdownPlacement?: string;
}

const { locale = "en", class: className, dropdownPlacement = "dropdown-end sm:dropdown-bottom dropdown-top" } = Astro.props;
const __ = await useTranslator(locale);
const themeDict = (await getTranslations(locale, "theme")) as Record<
    string,
    string
>;

const label = themeDict["label"] || __("Theme");

const themeKeys = [
    "light",
    "dark",
    "cupcake",
    "bumblebee",
    "emerald",
    "corporate",
    "synthwave",
    "retro",
    "cyberpunk",
    "valentine",
    "halloween",
    "garden",
    "forest",
    "aqua",
    "lofi",
    "pastel",
    "fantasy",
    "wireframe",
    "black",
    "luxury",
    "dracula",
    "cmyk",
    "autumn",
    "business",
    "acid",
    "lemonade",
    "night",
    "coffee",
    "winter",
    "dim",
    "nord",
    "sunset",
    "caramellatte",
    "abyss",
    "silk",
];

const themesList = themeKeys.map((key) => ({
    name: key,
    label: themeDict[key] || key,
}));
---

<div
    class:list={[
        "dropdown group",
        dropdownPlacement,
        className,
    ]}
>
    <!-- Accessible Trigger Button -->
    <button
        type="button"
        tabindex="0"
        class="btn btn-sm btn-ghost gap-2 px-3 rounded-box border border-base-content/5 hover:border-primary/30 transition-all hover:bg-base-content/5"
        aria-label={__("Change Theme")}
        title={__("Change Theme")}
    >
        <div
            class="grid grid-cols-2 gap-0.5 p-1 bg-base-content/5 rounded-box group-hover:bg-primary/20 transition-colors"
        >
            <div
                class="size-1.5 rounded-box bg-primary shadow-[0_0_4px_rgba(var(--p),0.5)]"
            >
            </div>
            <div class="size-1.5 rounded-box bg-secondary"></div>
            <div class="size-1.5 rounded-box bg-accent"></div>
            <div class="size-1.5 rounded-box bg-neutral"></div>
        </div>
        <span
            class="text-[10px] font-bold uppercase tracking-widest opacity-60 hidden xl:inline-block"
            >{label}</span
        >
        <svg
            width="10px"
            height="10px"
            class="fill-current opacity-40 transition-transform group-focus-within:rotate-180"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 2048 2048"
        >
            <path d="M1799 349l242 241-1017 1017L7 590l242-241 775 775 775-775z"
            ></path>
        </svg>
    </button>

    <div
        tabindex="0"
        class="dropdown-content mt-4 p-3 bg-base-100/90 backdrop-blur-sm border border-base-content/10 shadow-2xl rounded-box max-h-[60vh] overflow-y-auto scrollbar-hide z-[100] animate-in fade-in zoom-in-95 duration-200"
    >
        <div class="px-2 pb-3 mb-2 border-b border-base-content/5">
            <span
                class="text-[10px] font-black uppercase tracking-[0.2em] opacity-30"
                >{label}</span
            >
        </div>

        <ul class="flex flex-col gap-1">
            {
                themesList.map((theme) => (
                    <li>
                        <button
                            type="button"
                            data-set-theme={theme.name}
                            class="w-full flex items-center justify-between p-2 rounded-box text-sm font-medium hover:bg-primary/10 hover:text-primary transition-all group/item object-selected"
                        >
                            <div
                                data-theme={theme.name}
                                class="rounded-box bg-base flex items-center pr-3 pl-2 gap-3"
                            >
                                <div class="grid grid-cols-2 gap-0.5 p-1 rounded-box border border-base-content/10 bg-base-100">
                                    <div class="size-1.5 rounded-box bg-primary shadow-[0_0_4px_rgba(var(--p),0.5)]" />
                                    <div class="size-1.5 rounded-box bg-secondary" />
                                    <div class="size-1.5 rounded-box bg-accent" />
                                    <div class="size-1.5 rounded-box bg-neutral" />
                                </div>
                                <span class="capitalize tracking-tight">
                                    {theme.label}
                                </span>
                            </div>

                            <div class="size-4 rounded-box border border-base-content/20 flex items-center justify-center p-0.5 opacity-0 group-hover/item:opacity-40">
                                <div class="size-full rounded-box bg-primary opacity-0 group-hover/item:opacity-100 scale-0 group-hover/item:scale-100 transition-all" />
                            </div>
                        </button>
                    </li>
                ))
            }
        </ul>
    </div>
</div>

<script>
    function setupThemeToggle() {
        const themeButtons = document.querySelectorAll("[data-set-theme]");
        const currentTheme = localStorage.getItem("theme") || document.documentElement.getAttribute("data-theme") || "cupcake";

        const activeClasses = ["bg-primary/10", "text-primary"];

        // Reset all buttons first to be safe when layout re-renders
        themeButtons.forEach((b) => b.classList.remove(...activeClasses));

        themeButtons.forEach((btn) => {
            if (btn.getAttribute("data-set-theme") === currentTheme) {
                btn.classList.add(...activeClasses);
            }

            // Prevent double initialization if run multiple times
            if (btn.hasAttribute("data-theme-listener")) return;
            btn.setAttribute("data-theme-listener", "true");

            btn.addEventListener("click", () => {
                const theme = btn.getAttribute("data-set-theme");
                if (theme) {
                    document.documentElement.setAttribute("data-theme", theme);
                    localStorage.setItem("theme", theme);

                    themeButtons.forEach((b) => b.classList.remove(...activeClasses));
                    
                    // Sync up all other buttons pointing to this theme across the UI
                    document.querySelectorAll(`[data-set-theme="${theme}"]`).forEach(b => {
                        b.classList.add(...activeClasses);
                    });

                    // Optional: Close dropdown on select
                    if (document.activeElement instanceof HTMLElement) {
                        document.activeElement.blur();
                    }
                }
            });
        });
    }

    // Run on init and Astro view transitions
    document.addEventListener("astro:page-load", setupThemeToggle);
    setupThemeToggle();
</script>

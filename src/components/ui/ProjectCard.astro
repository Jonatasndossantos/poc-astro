---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { useTranslatedPath, useTranslator } from "@i18n";

interface Props {
    project: {
        id: string;
        title: string;
        imageUrl: string;
        demoUrl?: string;
        repoUrl?: string;
        technologies: { id: string; name: string }[];
        description: string;
        date?: any;
        relevance?: number;
        role?: string;
        company?: string;
    };
    lang: string;
    isFeatured?: boolean;
    isLcp?: boolean;
    caseStudyLabel: string;
    viewProjectLabel: string;
    codeLabel: string;
}

const {
    project,
    lang,
    isFeatured = false,
    isLcp = false,
    caseStudyLabel,
    viewProjectLabel,
    codeLabel,
} = Astro.props;
const translatePath = useTranslatedPath(lang);
const __ = await useTranslator(lang);

const descKey = `projects.items.${project.id}.description.fullstack`;
let localizedDesc = __(descKey);
if (localizedDesc === descKey) {
    localizedDesc = project.description;
}
---

<div
    class:list={[
        "card image-full group overflow-hidden bg-base-100 shadow-xl border border-base-content/5",
        isFeatured ? "md:col-span-2" : "md:col-span-1",
        "h-[400px]",
    ]}
>
    <figure>
        <Image
            src={project.imageUrl ||
                "https://images.unsplash.com/photo-1550745165-9bc0b252726f?q=80&w=800"}
            alt={__(project.title)}
            width={800}
            height={600}
            loading="lazy"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-60 group-hover:opacity-40"
        />
    </figure>

    <div
        class="card-body justify-end p-8 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500"
    >
        <div class="flex gap-2 mb-4 flex-wrap relative z-30">
            {
                project.technologies.slice(0, 3).map((tech) => (
                    <a
                        href={translatePath(`/tags/${tech.id}`)}
                        class="badge badge-outline badge-sm uppercase text-[10px] tracking-wider border-base-content/20 bg-base-100/20 hover:bg-primary hover:text-primary-content hover:scale-105 transition-all backdrop-blur-sm text-base-content"
                    >
                        {__(tech.name)}
                    </a>
                ))
            }
        </div>

        {
            (project.role || project.company || project.date) && (
                <div class="flex items-center gap-2 flex-wrap text-neutral-content/80 text-xs z-20 relative font-medium opacity-0 h-0 group-hover:opacity-100 group-hover:h-auto group-hover:mb-2 transition-all duration-300">
                    {project.date && (
                        <span>{new Date(project.date).getFullYear()}</span>
                    )}
                    {project.date && (project.role || project.company) && (
                        <span>&bull;</span>
                    )}
                    {project.company && (
                        <span class="uppercase tracking-wider opacity-80">
                            {project.company}
                        </span>
                    )}
                    {project.role && (
                        <span class="badge badge-neutral badge-sm border-neutral-content/20 bg-neutral/40 backdrop-blur-md">
                            {project.role}
                        </span>
                    )}
                </div>
            )
        }

        <h4
            class="card-title text-3xl font-bold text-neutral-content mb-2 shadow-sm relative z-20 transition-transform duration-300 group-hover:scale-105 origin-left"
        >
            <a
                href={translatePath(`/projects/${project.id}`)}
                class="hover:text-primary transition-colors cursor-pointer before:absolute before:inset-0 before:z-10 line-clamp-2"
                aria-label={__(project.title)}
            >
                {__(project.title)}
            </a>
        </h4>
        <p
            class="text-neutral-content/60 text-sm line-clamp-2 mb-4 group-hover:text-neutral-content/90 transition-colors grow-0 relative z-20 group-hover:line-clamp-none"
        >
            {localizedDesc}
        </p>

        <div
            class="card-actions flex gap-4 opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100 mt-auto relative z-20"
        >
            <a
                href={translatePath(`/projects/${project.id}`)}
                class="btn btn-primary btn-sm rounded-[calc(var(--radius-box)*2)] text-xs"
                aria-label={`${__("Read Case Study for")} ${__(project.title)}`}
            >
                {caseStudyLabel}
            </a>
            {
                project.demoUrl && (
                    <a
                        href={project.demoUrl}
                        target="_blank"
                        rel="noreferrer"
                        class="btn btn-outline btn-sm rounded-[calc(var(--radius-box)*2)] text-xs border-neutral-content/20 text-neutral-content hover:bg-neutral-content/10"
                        aria-label={`${__("Demo of")} ${__(project.title)}`}
                    >
                        <Icon
                            name="lucide:external-link"
                            class="size-4"
                            aria-hidden="true"
                        />
                        {viewProjectLabel}
                    </a>
                )
            }
            {
                project.repoUrl && (
                    <a
                        href={project.repoUrl}
                        target="_blank"
                        rel="noreferrer"
                        class="btn btn-ghost btn-sm rounded-[calc(var(--radius-box)*2)] text-xs text-neutral-content hover:bg-base-content/20"
                        aria-label={`${__("Source Code of")} ${__(project.title)}`}
                    >
                        <Icon
                            name="lucide:github"
                            class="size-4"
                            aria-hidden="true"
                        />
                        {codeLabel}
                    </a>
                )
            }
        </div>
    </div>
</div>

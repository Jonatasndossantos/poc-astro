---
import { useTranslatedPath, useTranslator } from "@i18n";
import { Image } from "astro:assets";

interface Props {
    post: {
        id: string;
        data: {
            title: string;
            date: Date;
            description?: string;
            heroImage?: string;
        };
    };
    lang: string;
}

const { post, lang } = Astro.props;
const translatePath = useTranslatedPath(lang);
const __ = await useTranslator(lang);
const cleanId = post.id.replace(/\.mdx?$/, "").split('/').pop();
---

<a 
    href={translatePath(`/blog/${cleanId}`)}
    class="flex flex-col h-full bg-base-100 border border-base-content/10 rounded-2xl hover:shadow-xl hover:border-primary/30 transition-all hover:-translate-y-1 group overflow-hidden"
    aria-label={`${__("Read article")}: ${post.data.title}`}
>
    <!-- Thumbnail -->
    <div class="relative w-full h-48 overflow-hidden bg-base-200">
        <Image
            src={post.data.heroImage || "https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=800"}
            alt=""
            width={400}
            height={200}
            loading="lazy"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div class="absolute top-4 left-4">
            <span class="px-2 py-1 bg-primary text-primary-content text-[8px] font-black uppercase tracking-[0.2em] rounded shadow-lg">
                {__("Article")}
            </span>
        </div>
    </div>

    <!-- Content -->
    <div class="flex flex-col p-6 h-full">
        <div class="flex items-center gap-3 mb-4">
            <time class="text-[10px] uppercase font-bold tracking-widest opacity-40">
                {new Date(post.data.date).toLocaleDateString(lang, { 
                    year: 'numeric', 
                    month: 'long'
                })}
            </time>
        </div>

        <h3 class="text-xl font-bold text-base-content mb-3 group-hover:text-primary transition-colors line-clamp-2 leading-tight">
            {post.data.title}
        </h3>

        {post.data.description && (
            <p class="text-xs text-base-content/50 line-clamp-3 mb-6 leading-relaxed">
                {post.data.description}
            </p>
        )}

        <div class="mt-auto flex items-center text-[10px] font-black uppercase tracking-widest text-primary opacity-0 group-hover:opacity-100 transition-all translate-x-[-10px] group-hover:translate-x-0">
            {__("Read Full Story")} <span class="ml-2 font-mono">&rarr;</span>
        </div>
    </div>
</a>
